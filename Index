<!DOCTYPE html>
<html>

<head>

<meta charset="utf-8">
<title>NL-FLab – 3D Artist</title>

<style>

/* ================================
   GLOBAL
================================ */

body{
margin:0;
background:#0f0f0f;
color:#e5e5e5;
font-family:-apple-system,BlinkMacSystemFont,sans-serif;
}

/* ================================
   HERO
================================ */

header{
padding:100px 12% 60px 12%;
}

h1{
font-size:40px;
margin:0;
font-weight:500;
letter-spacing:1px;
}

.subtitle{
margin-top:12px;
color:#888;
max-width:600px;
line-height:1.6;
}

/* ================================
   SECTION
================================ */

.section{
padding:60px 12%;
}

/* ================================
   ABOUT
================================ */

.about{
max-width:700px;
}

.about h2{
font-size:22px;
margin-bottom:20px;
}

.about p{
color:#aaa;
line-height:1.7;
}

/* ================================
   FILTER
================================ */

.filter{
margin-bottom:50px;
display:flex;
gap:20px;
flex-wrap:wrap;
}

.filter-btn{
background:none;
border:none;
color:#888;
font-size:14px;
cursor:pointer;
padding:6px 0;
}

.filter-btn.active{
color:white;
border-bottom:1px solid white;
}

/* ================================
   GRID
================================ */

.grid{
display:grid;
grid-template-columns:
repeat(auto-fit,minmax(280px,1fr));
gap:70px;
max-width:1100px;
}

/* ================================
   PROJECT CARD
================================ */

.project{

position:relative;
overflow:hidden;
border-radius:8px;

}

/* cinematic crop */

.project img{

width:100%;
height:340px;

object-fit:cover;

display:block;

transition:0.4s;

}

/* overlay */

.overlay{

position:absolute;
bottom:0;
left:0;

width:100%;
height:60%;

background:linear-gradient(
transparent,
rgba(0,0,0,0.85)
);

opacity:0;

transition:0.3s;

}

/* title */

.project-title{

position:absolute;
bottom:20px;
left:20px;

font-size:14px;
letter-spacing:1px;

opacity:0;
transform:translateY(10px);

transition:0.35s;

}

/* hover */

.project:hover img{
transform:scale(1.05);
}

.project:hover .overlay{
opacity:1;
}

.project:hover .project-title{
opacity:1;
transform:translateY(0);
}

/* ================================
   CONTACT
================================ */

.contact{
max-width:600px;
}

.contact a{
display:block;
margin-bottom:10px;
color:#aaa;
}

/* ================================
   FOOTER
================================ */

footer{
padding:80px 12%;
color:#555;
font-size:13px;
}

a{
text-decoration:none;
color:inherit;
}

</style>

</head>

<body>

<!-- ================================
     HERO
================================ -->

<header>

<h1>NL-FLab</h1>

<div class="subtitle">

3D Artist specializing in product visualization
and high-quality modeling.

</div>

</header>


<!-- ================================
     ABOUT
================================ -->

<div class="section about">

<h2>About</h2>

<p>

3D Artist with 7+ years experience in product
visualization and modeling pipelines.

</p>

<p>

Experienced with 3ds Max, Substance, Photoshop,
and V-Ray for production-ready assets.

</p>

</div>


<!-- ================================
     FILTER
================================ -->

<div class="section">

<div class="filter">

<button class="filter-btn active" data-filter="all">All</button>

<button class="filter-btn" data-filter="A">Project A</button>

<button class="filter-btn" data-filter="B">Project B</button>

<button class="filter-btn" data-filter="C">Project C</button>

<button class="filter-btn" data-filter="D">Project D</button>

<button class="filter-btn" data-filter="E">Project E</button>

</div>


<!-- grid project -->

<div class="grid" id="projectGrid"></div>

</div>


<!-- ================================
     CONTACT
================================ -->

<div class="section contact">

<h2>Contact</h2>

<a href="mailto:lenghia7991@gmail.com">

Email: lenghia7991@gmail.com

</a>

<a href="#">
LinkedIn
</a>

<a href="#">
ArtStation
</a>

<a href="#">
Sketchfab
</a>

</div>


<footer>

© NL-FLab

</footer>


<script>

/* =================================
   DEMO PROJECT DATA
   sau này sẽ chuyển sang JSON
================================= */

const projects=[

{
title:"Project A – Shoe",
image:"images/Shoe_001/Hero.jpg",
link:"projects/Shoe_001.html",
category:"A"
},

{
title:"Project A – Shoe 02",
image:"images/Shoe_001/Hero.jpg",
link:"projects/Shoe_001.html",
category:"A"
},

{
title:"Project B – Chair",
image:"images/Shoe_001/Hero.jpg",
link:"projects/Shoe_001.html",
category:"B"
},

{
title:"Project C – Watch",
image:"images/Shoe_001/Hero.jpg",
link:"projects/Shoe_001.html",
category:"C"
},

{
title:"Project D – Product",
image:"images/Shoe_001/Hero.jpg",
link:"projects/Shoe_001.html",
category:"D"
},

{
title:"Project E – Personal",
image:"images/Shoe_001/Hero.jpg",
link:"projects/Shoe_001.html",
category:"E"
}

]

/* =================================
   render project
================================= */

function renderProjects(category){

const grid=document.getElementById("projectGrid")

grid.innerHTML=""

const filtered=category==="all"
?projects
:projects.filter(p=>p.category===category)

filtered.forEach(p=>{

const item=document.createElement("a")

item.href=p.link

item.innerHTML=`

<div class="project">

<img src="${p.image}">

<div class="overlay"></div>

<div class="project-title">

${p.title}

</div>

</div>

`

grid.appendChild(item)

})

}

renderProjects("all")

/* =================================
   filter click
================================= */

document.querySelectorAll(".filter-btn")
.forEach(btn=>{

btn.addEventListener("click",()=>{

document
.querySelectorAll(".filter-btn")
.forEach(b=>b.classList.remove("active"))

btn.classList.add("active")

renderProjects(btn.dataset.filter)

})

})

</script>

</body>
</html>
